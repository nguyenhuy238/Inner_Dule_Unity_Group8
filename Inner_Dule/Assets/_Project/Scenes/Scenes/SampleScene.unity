  m_Name: 
  m_EditorClassIdentifier: 
  introPanel: {fileID: 0}
  introText: {fileID: 0}
  introQuotes:
  - "H\xF4m nay l\xE0 m\u1ED9t ng\xE0y d\xE0i... t\xE2m tr\xED t\xF4i kh\xF4ng th\u1EC3
    y\xEAn \u0111\u1ECBnh."
  - "Cu\u1ED9c chi\u1EBFn n\u1ED9i t\xE2m kh\xF4ng ph\u1EA3i \u0111\u1EC3 ti\xEAu
    di\u1EC7t, m\xE0 \u0111\u1EC3 t\xECm th\u1EA5y s\u1EF1 c\xE2n b\u1EB1ng."
  - "Gi\u1EEFa hai th\xE1i c\u1EF1c, \u0111\xE2u l\xE0 con \u0111\u01B0\u1EDDng d\u1EABn
    \u0111\u1EBFn h\xF2a h\u1EE3p?"
  gameplayPanel: {fileID: 0}
  player1HealthBar: {fileID: 2001861175}
  player2HealthBar: {fileID: 1046925945}
  player1Name: {fileID: 0}
  player2Name: {fileID: 0}
  endingPanel: {fileID: 0}
  endingText: {fileID: 0}
  harmonyText: {fileID: 0}
  harmonyQuotes:
  - "S\u1EF1 c\xE2n b\u1EB1ng kh\xF4ng ph\u1EA3i l\xE0 \u0111\xEDch \u0111\u1EBFn,
    \u0111\xF3 l\xE0 m\u1ED9t h\xE0nh tr\xECnh."
  - "Chi\u1EBFn th\u1EAFng b\u1EA3n th\xE2n l\xE0 chi\u1EBFn th\u1EAFng hi\u1EC3n
    h\xE1ch nh\u1EA5t."
  - "H\xF2a h\u1EE3p kh\xF4ng ph\u1EA3i l\xE0 s\u1EF1 gi\u1ED1ng nhau, m\xE0 l\xE0
    s\u1EF1 b\u1ED5 sung cho nhau."
  - "T\u1EEB \u0111\u1ED1i \u0111\u1EA7u \u0111\u1EBFn th\u1EA5u hi\u1EC3u, \u0111\xF3
    ch\xEDnh l\xE0 s\u1EF1 tr\u01B0\u1EDFng th\xE0nh."
